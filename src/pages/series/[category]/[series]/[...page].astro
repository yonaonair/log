---
export const prerender = true;

import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getCategoryTree from "@/utils/getCategoryTree";
import getPostsBySeries from "@/utils/getPostsBySeries";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const tree = getCategoryTree(posts);

  return tree.flatMap(({ category, categoryName, seriesNodes }) =>
    seriesNodes.flatMap(({ series, seriesName }) => {
      const seriesPosts = getPostsBySeries(posts, category, series);
      return paginate(seriesPosts, {
        params: { category, series },
        props: { categoryName, seriesName },
        pageSize: SITE.postPerPage,
      });
    })
  );
}

const { category, series } = Astro.params;
const { page, categoryName, seriesName } = Astro.props;
---

<Layout title={`${seriesName} | ${categoryName} | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle={[`${categoryName} /`, `${seriesName}`]}
    titleTransition={series}
    pageDesc={`"${seriesName}" 시리즈의 모든 글`}
  >
    <h1 slot="title" transition:name={series}>
      {categoryName} / {seriesName}
    </h1>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
