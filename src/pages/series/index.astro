---
export const prerender = true;

import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getCategoryTree from "@/utils/getCategoryTree";
import postFilter from "@/utils/postFilter";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const tree = getCategoryTree(posts);
const uncategorized = posts.filter(p => postFilter(p) && !p.data.series);
---

<Layout title={`Series | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Series" pageDesc="Posts grouped by category and series.">
    <ul class="flex flex-col gap-8">
      {
        tree.map(({ category, categoryName, seriesNodes, totalPosts }) => (
          <li>
            <a
              href={`/series/${category}/`}
              class:list={[
                "flex items-baseline gap-2",
                "border-b-2 border-dashed border-foreground text-xl font-semibold",
                "hover:-mt-0.5 hover:border-accent hover:text-accent",
                "focus-visible:border-none focus-visible:text-accent",
              ]}
            >
              {categoryName}
              <span class="text-sm font-normal opacity-60">{totalPosts}편</span>
            </a>
            <ul class="mt-3 flex flex-col gap-2 ps-4">
              {seriesNodes.map(({ series, seriesName, count }) => (
                <li>
                  <a
                    href={`/series/${category}/${series}/`}
                    class:list={[
                      "flex items-baseline gap-2 text-base",
                      "opacity-80 hover:opacity-100 hover:text-accent",
                      "focus-visible:text-accent",
                    ]}
                  >
                    <span class="opacity-50">└</span>
                    {seriesName}
                    <span class="text-sm opacity-60">{count}편</span>
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ))
      }

      {
        uncategorized.length > 0 && (
          <li>
            <a
              href="/series/uncategorized/"
              class:list={[
                "flex items-baseline gap-2",
                "border-b-2 border-dashed border-foreground text-xl font-semibold opacity-50",
                "hover:-mt-0.5 hover:border-accent hover:text-accent hover:opacity-100",
                "focus-visible:border-none focus-visible:text-accent",
              ]}
            >
              분류 없음
              <span class="text-sm font-normal opacity-60">
                {uncategorized.length}편
              </span>
            </a>
          </li>
        )
      }
    </ul>
  </Main>
  <Footer />
</Layout>
